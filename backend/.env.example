# Copy to .env and fill in values. SECRET_KEY is required in production.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/codoxis

# JWT signing key (required). Use a long random string.
SECRET_KEY=change-me-to-random-string

# OpenRouter API key for AI features
OPENROUTER_API_KEY=sk-or-...

# GitHub OAuth (optional, for GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000
